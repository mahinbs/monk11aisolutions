{
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!static|videos|logo\\.png|manifest\\.json|robots\\.txt|sitemap\\.xml|favicon\\.ico|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
